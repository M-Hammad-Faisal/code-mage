# ── Supabase ──────────────────────────────────
# Project URL — found in: Dashboard → Settings → API
SUPABASE_URL=https://your-project.supabase.co

# Publishable key (sb_publishable_...) — new format key, server-side only
# Found in: Dashboard → Settings → API Keys → Publishable key
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# Secret key (sb_secret_...) — SERVER ONLY, never expose to client
# Found in: Dashboard → Settings → API Keys → Secret keys
SUPABASE_SECRET_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxx

# ── Site ──────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://code-mage.vercel.app

# ── Optional ──────────────────────────────────
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
